# Environment Variables Example
# Скопируйте этот файл в .env и заполните значения
# Команда: cp env.example .env
#
# Важно: Для production заполните все обязательные переменные (отмечены как REQUIRED)
# Опциональные переменные можно оставить пустыми или использовать значения по умолчанию

# ============================================
# Yandex Cloud Configuration
# ============================================
# REQUIRED for Yandex Cloud deployment
YC_FOLDER_ID=b1gfl9cu32kktuuthcf3
YC_REGISTRY_ID=your_registry_id_here
YC_SERVICE_ACCOUNT_ID=your_service_account_id_here
YC_ACCESS_KEY_ID=your_access_key_id_here
YC_SECRET_ACCESS_KEY=your_secret_access_key_here

# ============================================
# Application Settings
# ============================================
NODE_ENV=development
APP_NAME=Jack AI Service
APP_VERSION=0.1.0

# ============================================
# Service Ports (каждый сервис использует свой PORT)
# ============================================
# User Profile Service
USER_PROFILE_PORT=3001

# Conversation Service
CONVERSATION_PORT=3002

# AI/NLP Service
AI_NLP_PORT=3003

# Job Matching Service
JOB_MATCHING_PORT=3004

# Email Notification Service
EMAIL_PORT=3005

# Frontend
FRONTEND_PORT=3000

# ============================================
# Database (PostgreSQL)
# ============================================
# REQUIRED: Настройки подключения к PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=jack_ai
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_SSL=false

# ============================================
# Redis
# ============================================
# REQUIRED: Настройки подключения к Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Redis prefix для изоляции данных (опционально)
REDIS_PREFIX=

# ============================================
# AI/NLP Services - YandexGPT
# ============================================
# REQUIRED для AI/NLP Service: Yandex Cloud настройки
# Получите в Yandex Cloud Console: https://console.cloud.yandex.ru/
YC_FOLDER_ID=your_yandex_folder_id_here
YC_API_KEY=your_yandex_api_key_here
YC_MODEL_ID=foundation-models/yandexgpt-lite

# Опциональные настройки YandexGPT
YC_TEMPERATURE=0.6
YC_MAX_TOKENS=800
YC_TOP_P=0.9

# OpenAI (не используется в текущей версии, можно удалить)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4

# Anthropic Claude (не используется в текущей версии, можно удалить)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-opus-20240229

# ============================================
# Vector Database (планируется)
# ============================================
# Pinecone
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_ENVIRONMENT=us-east-1
PINECONE_INDEX_NAME=jack-jobs

# Weaviate (альтернатива)
WEAVIATE_URL=http://localhost:8080
WEAVIATE_API_KEY=

# ============================================
# Email Service - SMTP (Yandex Mail) или SendGrid
# ============================================
# ПРИОРИТЕТ: SMTP (Yandex Mail) > SendGrid
# Если настроен SMTP, он будет использоваться. SendGrid - fallback.

# SMTP Configuration (Yandex Mail) - РЕКОМЕНДУЕТСЯ
# Инструкция: https://id.yandex.ru/security -> Пароли приложений
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-email@yandex.ru
SMTP_PASSWORD=your_app_password_here

# Email отправителя (используется для SMTP и SendGrid)
FROM_EMAIL=your-email@yandex.ru
FROM_NAME=Jack AI

# SendGrid (альтернатива, используется если SMTP не настроен)
# Получите на https://sendgrid.com/
SENDGRID_API_KEY=your_sendgrid_api_key_here

# Альтернатива: Mailgun (не используется в текущей версии)
MAILGUN_API_KEY=your_mailgun_api_key_here
MAILGUN_DOMAIN=your_domain_here

# Base URL для ссылок в email
BASE_URL=http://localhost:3000

# ============================================
# Authentication
# ============================================
# REQUIRED: JWT секретный ключ (должен быть одинаковым во всех сервисах!)
# В production используйте длинный случайный ключ
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_key_here
JWT_REFRESH_EXPIRES_IN=30d

# ============================================
# Job Scraping
# ============================================
# HeadHunter.ru API (опционально, без ключа используются mock данные)
# Получите на https://dev.hh.ru/
HH_API_KEY=your_hh_api_key_here
HH_API_URL=https://api.hh.ru
SCRAPER_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36

# Использование mock данных для тестирования
# Если true - будет использоваться mock данные вместо реального скрейпинга
# Для production установите false
USE_MOCK_JOBS=false

# LinkedIn Jobs API (если доступен)
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret

# Indeed API
INDEED_API_KEY=your_indeed_api_key

# ============================================
# Service URLs (для межсервисного взаимодействия)
# ============================================
# REQUIRED: URL сервисов для межсервисной коммуникации
USER_PROFILE_SERVICE_URL=http://localhost:3001
CONVERSATION_SERVICE_URL=http://localhost:3002
AI_SERVICE_URL=http://localhost:3003
AI_NLP_SERVICE_URL=http://localhost:3003
JOB_MATCHING_SERVICE_URL=http://localhost:3004
EMAIL_SERVICE_URL=http://localhost:3005

# Frontend URLs (для CORS и ссылок)
CORS_ORIGIN=http://localhost:3000

# ============================================
# Frontend Environment Variables
# ============================================
# Эти переменные доступны в браузере (префикс NEXT_PUBLIC_)
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_CONVERSATION_API_URL=http://localhost:3002
NEXT_PUBLIC_CONVERSATION_SERVICE_URL=http://localhost:3002

# ============================================
# External Integrations
# ============================================
# Jill Service (internal API) - планируется
JILL_SERVICE_URL=http://localhost:3001
JILL_SERVICE_API_KEY=your_jill_service_api_key

# ============================================
# Logging
# ============================================
LOG_LEVEL=info
LOG_FORMAT=json

# ============================================
# Monitoring
# ============================================
# Sentry (для отслеживания ошибок)
SENTRY_DSN=your_sentry_dsn_here

# DataDog (для мониторинга)
DD_API_KEY=your_datadog_api_key_here
DD_APP_KEY=your_datadog_app_key_here

# ============================================
# Rate Limiting
# ============================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
