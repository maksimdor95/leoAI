TELEGRAM_BOT_TOKEN=
TELEGRAM_SUPPORT_CHAT_ID=-5120978370
TELEGRAM_SITE_URL=https://leoai.com

# --- VPS production / staging (recommended) ---
TELEGRAM_STRICT_CONFIG=true
BIND_HOST=127.0.0.1
# Comma-separated Telegram user IDs allowed to reply in LEO Support group:
TELEGRAM_OPERATOR_IDS=564582497
TELEGRAM_PROXY_URL=socks5h://127.0.0.1:40000
TELEGRAM_USE_POLLING=true

# Webhook via leo-ai.ru (ngrok blocked on RU VPS IP) — alternative to polling:
# TELEGRAM_USE_POLLING=false
# TELEGRAM_WEBHOOK_URL=https://leo-ai.ru/telegram/webhook
# TELEGRAM_WEBHOOK_SECRET=random_long_secret_string

# Dev on Mac (no proxy if Telegram API is reachable directly):
# TELEGRAM_USE_POLLING=true
# TELEGRAM_STRICT_CONFIG=false
PORT=3008
