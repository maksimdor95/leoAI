TELEGRAM_BOT_TOKEN=
TELEGRAM_SUPPORT_CHAT_ID=-5120978370
TELEGRAM_SITE_URL=https://leoai.com
# Optional: restrict who can reply in the support group
# TELEGRAM_OPERATOR_IDS=564582497
# Outbound proxy when api.telegram.org is blocked (HTTP/HTTPS/SOCKS5):
# TELEGRAM_PROXY_URL=socks5h://127.0.0.1:40000
# Use socks5h (not socks5) so DNS goes through the proxy — required for Telegram from RU VPS.

# VPS 24/7 via ngrok webhook:
# TELEGRAM_USE_POLLING=false
# TELEGRAM_NGROK_AUTOSYNC=true
# TELEGRAM_WEBHOOK_SECRET=random_secret_string
# TELEGRAM_WEBHOOK_URL=https://your-static-domain.ngrok.app/telegram/webhook

# Dev on Mac:
# TELEGRAM_USE_POLLING=true
PORT=3008
