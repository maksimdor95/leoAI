{
  "name": "jack-ai-service",
  "version": "0.1.0",
  "description": "AI assistant for job seekers - Jack service",
  "private": true,
  "scripts": {
    "dev:up": "bash ./scripts/dev/up.sh",
    "dev:up:docker": "bash ./scripts/dev/up.sh --with-docker",
    "dev:up:staging": "bash ./scripts/dev/up.sh --env-file .env.staging.local",
    "dev:down": "bash ./scripts/dev/down.sh",
    "dev:down:docker": "bash ./scripts/dev/down.sh --with-docker",
    "dev:clean-start": "bash ./scripts/dev/clean-start.sh",
    "dev:clean-start:docker": "bash ./scripts/dev/clean-start.sh --with-docker",
    "dev:status": "bash ./scripts/dev/status.sh",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx --ignore-path .eslintignore",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,md,yml,yaml}\"",
    "smoke:mvp0": "bash ./scripts/smoke/mvp0-smoke.sh",
    "smoke:mvp0:full": "SMOKE_MODE=full bash ./scripts/smoke/mvp0-smoke.sh",
    "smoke:mvp0:full:auto": "bash ./scripts/smoke/mvp0-full-run.sh",
    "smoke:mvp0:gate": "RUNS=5 bash ./scripts/smoke/mvp0-full-run.sh",
    "smoke:mvp0:pre-release": "bash ./scripts/smoke/mvp0-pre-release.sh",
    "smoke:resume": "node ./services/user-profile/scripts/resume-extraction-smoke.js",
    "smoke:resume:batch": "node ./services/user-profile/scripts/resume-extraction-batch-smoke.js",
    "prepare": "husky install"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.50.0",
    "eslint-config-prettier": "^9.0.0",
    "husky": "^8.0.3",
    "lint-staged": "^14.0.1",
    "next": "^14.0.4",
    "prettier": "^3.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
