# VPS example: /etc/caddy/Caddyfile
# Requires Caddy built with github.com/mholt/caddy-ratelimit (see scripts/dev/install-caddy-ratelimit-vps.sh).
# Stock apt Caddy does NOT include rate_limit.
# Order matters — specific /api/* routes before catch-alls.

leo-ai.ru {
    encode gzip

    # --- Rate limits (per IP) — complement app-level limits ---
    # Use block matchers: inline `method POST path ...` parses incorrectly in Caddy.
    @user_login {
        method POST
        path /api/users/login
    }
    handle @user_login {
        rate_limit {
            zone user_login {
                key {remote_host}
                events 10
                window 1m
            }
        }
        reverse_proxy 127.0.0.1:3001
    }

    @user_register {
        method POST
        path /api/users/register /api/users
    }
    handle @user_register {
        rate_limit {
            zone user_register {
                key {remote_host}
                events 10
                window 1m
            }
        }
        reverse_proxy 127.0.0.1:3001
    }

    @forgot_password {
        method POST
        path /api/users/forgot-password
    }
    handle @forgot_password {
        rate_limit {
            zone forgot_password {
                key {remote_host}
                events 5
                window 1m
            }
        }
        reverse_proxy 127.0.0.1:3001
    }

    @consultation {
        method POST
        path /api/email/send-consultation
    }
    handle @consultation {
        rate_limit {
            zone consultation {
                key {remote_host}
                events 5
                window 1m
            }
        }
        reverse_proxy 127.0.0.1:3005
    }

    handle /api/health {
        reverse_proxy 127.0.0.1:3000
    }
    handle /socket.io/* {
        reverse_proxy 127.0.0.1:3002
    }
    # Use explicit path matchers — `/api/chat*` does NOT match `/api/chat/session` in Caddy.
    @chat_api {
        path /api/chat /api/chat/*
    }
    handle @chat_api {
        reverse_proxy 127.0.0.1:3002
    }
    @conversations_api {
        path /api/conversations /api/conversations/*
    }
    handle @conversations_api {
        reverse_proxy 127.0.0.1:3002
    }
    # application-draft lives on conversation, not job-matching — before @jobs_api catch-all.
    @jobs_application_draft {
        method POST
        path /api/jobs/*/application-draft
    }
    handle @jobs_application_draft {
        reverse_proxy 127.0.0.1:3002
    }
    @ai_api {
        path /api/ai /api/ai/*
    }
    handle @ai_api {
        reverse_proxy 127.0.0.1:3003
    }
    @jobs_api {
        path /api/jobs /api/jobs/*
    }
    handle @jobs_api {
        reverse_proxy 127.0.0.1:3004
    }
    @email_api {
        path /api/email /api/email/*
    }
    handle @email_api {
        reverse_proxy 127.0.0.1:3005
    }
    # Telegram support webhook (when TELEGRAM_USE_POLLING=false)
    handle /telegram/webhook {
        reverse_proxy 127.0.0.1:3008
    }
    handle /api/* {
        reverse_proxy 127.0.0.1:3001
    }
    handle {
        reverse_proxy 127.0.0.1:3000
    }
}
